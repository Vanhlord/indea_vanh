{
  "name": "mcnote-web",
  "version": "1.0.0",
  "description": "MC Note Server Web Interface",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "start-helper.bat",
    "dev": "nodemon server.js",
    "test:sidebar": "node tests/runSidebarTest.js",
    "test:smoke": "node tests/runSmokeTest.js",
    "check:min": "npm run lint && npm run test:smoke",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "prepare": "husky install"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bedrock-protocol": "^3.52.0",
    "bedrock-provider": "^3.1.0",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "cluster": "^0.7.7",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "fs-extra": "^11.3.3",
    "helmet": "^8.0.0",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "leveldb-zlib": "^1.2.0",
    "multer": "^2.0.2",
    "pm2": "^6.0.14",
    "prismarine-block": "^1.23.0",
    "prismarine-chunk": "^1.40.0",
    "prismarine-registry": "^1.12.0",
    "redis": "^4.6.13",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "systeminformation": "^5.30.5",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^3.25.54"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "playwright": "^1.40.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add"
    ]
  }
}
