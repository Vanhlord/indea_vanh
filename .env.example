# Server Configuration
PORT=3000
NODE_ENV=development

# PikaMC Server Configuration
PIKAMC_PANEL_URL=https://cp.pikamc.vn
PIKAMC_API_KEY=your_pikamc_api_key_here
PIKAMC_SERVER_ID=e417ea4b
WHITELIST_COMMAND_TEMPLATE=whitelist add "{gamertag}"

# Secondary Pterodactyl Configuration
SECONDARY_PTERODACTYL_PANEL_URL=https://your-pterodactyl-panel.com
SECONDARY_PTERODACTYL_API_KEY=your_pterodactyl_api_key_here
SECONDARY_PTERODACTYL_SERVER_ID=your_server_id_here

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID_1=your_channel_id_1_here
DISCORD_CHANNEL_ID_2=your_channel_id_2_here
DISCORD_DONATE_CHANNEL_ID=your_donate_channel_id_here
DISCORD_ADMIN_ID=your_admin_discord_id_here
DISCORD_EMBED_ALLOWED_IDS=admin_id_1,admin_id_2

# Chat Configuration
MAX_CHAT_HISTORY=100

# Session Configuration
SESSION_SECRET=your_session_secret_change_in_production
SESSION_COOKIE_NAME=sessionId
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=localhost

# Cache Configuration
DISABLE_REDIS=false

# Database URL (nếu dùng)
DATABASE_URL=

# OAuth Configuration
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
